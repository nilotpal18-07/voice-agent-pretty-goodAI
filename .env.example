# Copy to .env and fill in real values. .env is gitignored; this template is tracked.

# --- LiveKit ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- SIP outbound trunk (created in LiveKit, backed by Telnyx) ---
# The only trunk var read at runtime. Starts with "ST_".
SIP_OUTBOUND_TRUNK_ID=ST_your_trunk_id

# --- Deepgram (STT) ---
DEEPGRAM_API_KEY=your_deepgram_api_key

# --- Google (LLM: gemini-2.5-flash via the Gemini Developer API, not Vertex) ---
GOOGLE_API_KEY=your_google_api_key

# --- Cartesia (TTS) ---
CARTESIA_API_KEY=your_cartesia_api_key

# --- Telnyx (SIP trunk provider — documentation only; NOT read at runtime) ---
# These live in the LiveKit trunk config (created once via `lk sip outbound create`);
# the app references the trunk solely through SIP_OUTBOUND_TRUNK_ID above.
TELNYX_PHONE_NUMBER=+1XXXXXXXXXX
TELNYX_SIP_USERNAME=your_telnyx_sip_username
TELNYX_SIP_DOMAIN=sip.telnyx.com
